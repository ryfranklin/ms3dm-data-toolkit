# SQL Server SA password (used by all services)
SA_PASSWORD=YourStrong@Passw0rd

# Override these in production to point to a different SQL Server for metadata
# MS3DM_METADATA_HOST=your-sql-server-host
# MS3DM_METADATA_PORT=1433
# MS3DM_METADATA_USER=your-user
# MS3DM_METADATA_PASSWORD=your-password
# MS3DM_METADATA_DATABASE=DataToolkit

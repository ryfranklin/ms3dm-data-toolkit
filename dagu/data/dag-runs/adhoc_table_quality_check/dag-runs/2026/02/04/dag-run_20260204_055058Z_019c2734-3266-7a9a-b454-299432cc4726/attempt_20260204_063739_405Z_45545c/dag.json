{"workingDir":"/var/lib/dagu/dags","location":"/var/lib/dagu/dags/adhoc_table_quality_check.yaml","name":"adhoc_table_quality_check","type":"chain","shell":"/usr/bin/sh","dotenv":[".env"],"tags":["data-quality","on-demand","flexible"],"description":"On-demand comprehensive quality check for any table","env":["API_URL=http://backend:8000"],"logOutput":"separate","defaultParams":"default=\"SalesLT\" name=\"schema\" default=\"Customer\" name=\"table\" default=\"local_adventureworks\" name=\"connection_id\"","params":["default=SalesLT","name=schema","default=Customer","name=table","default=local_adventureworks","name=connection_id"],"paramsJSON":"{\"default\":\"local_adventureworks\",\"name\":\"connection_id\"}","steps":[{"name":"get_table_schema","description":"Retrieve table structure","script":"curl -s -X POST ${API_URL}/api/expectations/table-schema \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"connection_id\": \"'${connection_id}'\",\n    \"schema\": \"'${schema}'\",\n    \"table\": \"'${table}'\"\n  }'","output":"TABLE_SCHEMA"},{"name":"run_null_checks","description":"Check for NULL values in all columns","script":"# This would dynamically generate checks for all columns\n# For demo, checking first column\ncurl -X POST ${API_URL}/api/expectations/run-adhoc \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"name\": \"NULL Check - '${table}'\",\n    \"connection_id\": \"'${connection_id}'\",\n    \"expectations\": [\n      {\n        \"type\": \"expect_table_row_count_to_be_between\",\n        \"params\": {\"min_rows\": 1},\n        \"target\": {\"schema\": \"'${schema}'\", \"table\": \"'${table}'\"}\n      }\n    ]\n  }'","output":"NULL_CHECK_RESULTS","depends":["get_table_schema"]},{"name":"run_uniqueness_checks","description":"Check for duplicate records","script":"echo \"Running uniqueness checks on ${schema}.${table}\"\ncurl -X POST ${API_URL}/api/expectations/run-adhoc \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"name\": \"Uniqueness Check - '${table}'\",\n    \"connection_id\": \"'${connection_id}'\",\n    \"expectations\": [\n      {\n        \"type\": \"expect_table_row_count_to_be_between\",\n        \"params\": {\"min_rows\": 1},\n        \"target\": {\"schema\": \"'${schema}'\", \"table\": \"'${table}'\"}\n      }\n    ]\n  }'","output":"UNIQUENESS_RESULTS","depends":["get_table_schema","run_null_checks"]},{"name":"generate_quality_profile","description":"Create data quality profile for the table","script":"echo \"=== Data Quality Profile ===\" \u003e /var/lib/dagu/logs/quality_profile_${schema}_${table}_$(date +%Y%m%d_%H%M%S).json\necho '{\n  \"table\": \"'${schema}'.'${table}'\",\n  \"timestamp\": \"'$(date -Iseconds)'\",\n  \"schema\": '${TABLE_SCHEMA}',\n  \"null_checks\": '${NULL_CHECK_RESULTS}',\n  \"uniqueness_checks\": '${UNIQUENESS_RESULTS}'\n}' | jq '.' \u003e\u003e /var/lib/dagu/logs/quality_profile_${schema}_${table}_$(date +%Y%m%d_%H%M%S).json\n\necho \"✅ Quality profile generated for ${schema}.${table}\"\ncat /var/lib/dagu/logs/quality_profile_${schema}_${table}_$(date +%Y%m%d_%H%M%S).json","depends":["run_null_checks","run_uniqueness_checks"]},{"name":"summary_report","description":"Display summary of quality checks","script":"echo \"================================\"\necho \"Table: ${schema}.${table}\"\necho \"Connection: ${connection_id}\"\necho \"Timestamp: $(date)\"\necho \"================================\"\necho \"\"\necho \"NULL Checks:\"\necho \"${NULL_CHECK_RESULTS}\" | jq -r '.statistics'\necho \"\"\necho \"Uniqueness Checks:\"\necho \"${UNIQUENESS_RESULTS}\" | jq -r '.statistics'\necho \"\"\necho \"================================\"","depends":["generate_quality_profile"]}],"handlerOn":{"exit":{"name":"onExit","commands":[{"command":"echo","args":["Quality check completed for ${schema}.${table} at $(date)"],"cmdWithArgs":"echo \"Quality check completed for ${schema}.${table} at $(date)\""}]}},"maxActiveRuns":1,"maxCleanUpTime":5000000000,"histRetentionDays":30,"maxOutputSize":1048576,"yamlData":""}
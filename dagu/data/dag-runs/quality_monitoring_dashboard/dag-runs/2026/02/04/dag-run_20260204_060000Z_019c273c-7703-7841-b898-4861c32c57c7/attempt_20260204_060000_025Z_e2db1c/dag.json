{"workingDir":"/var/lib/dagu/dags","location":"/var/lib/dagu/dags/quality_monitoring_dashboard.yaml","name":"quality_monitoring_dashboard","type":"chain","shell":"/bin/bash","dotenv":[".env"],"tags":["monitoring","dashboard","metrics"],"description":"Track data quality metrics and trends across all tables","schedule":[{"expression":"0 */6 * * *"}],"env":["API_URL=http://backend:8000","CONNECTION_ID=local_adventureworks"],"logOutput":"separate","steps":[{"name":"discover_all_tables","description":"Get list of all tables in database","executorConfig":{},"script":"curl -s -X POST ${API_URL}/api/expectations/available-tables \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"connection_id\": \"'${CONNECTION_ID}'\"}' | jq -c '.'","output":"ALL_TABLES"},{"name":"collect_table_statistics","description":"Gather row counts and basic stats for all tables","executorConfig":{},"script":"echo \"Collecting statistics at $(date)\"\n\n# Create stats file\nSTATS_FILE=\"/var/lib/dagu/data/table_stats_$(date +%Y%m%d_%H%M%S).json\"\necho '{\n  \"timestamp\": \"'$(date -Iseconds)'\",\n  \"connection\": \"'${CONNECTION_ID}'\",\n  \"tables\": '${ALL_TABLES}'\n}' | jq '.' \u003e ${STATS_FILE}\n\necho \"Statistics saved to: ${STATS_FILE}\"\ncat ${STATS_FILE}","output":"STATS_FILE_PATH","depends":["discover_all_tables"]},{"name":"check_critical_tables","description":"Run quality checks on business-critical tables","executorConfig":{},"script":"curl -X POST ${API_URL}/api/expectations/run-adhoc \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"name\": \"Critical Tables Monitoring\",\n    \"connection_id\": \"'${CONNECTION_ID}'\",\n    \"expectations\": [\n      {\n        \"type\": \"expect_table_row_count_to_be_between\",\n        \"params\": {\"min_rows\": 1},\n        \"target\": {\"schema\": \"SalesLT\", \"table\": \"Customer\"}\n      },\n      {\n        \"type\": \"expect_table_row_count_to_be_between\",\n        \"params\": {\"min_rows\": 1},\n        \"target\": {\"schema\": \"SalesLT\", \"table\": \"Product\"}\n      },\n      {\n        \"type\": \"expect_table_row_count_to_be_between\",\n        \"params\": {\"min_rows\": 1},\n        \"target\": {\"schema\": \"SalesLT\", \"table\": \"SalesOrderHeader\"}\n      }\n    ]\n  }'","output":"CRITICAL_CHECKS","depends":["collect_table_statistics"]},{"name":"analyze_quality_trends","description":"Compare current metrics with historical data","executorConfig":{},"script":"echo \"=== Quality Trend Analysis ===\" \u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\necho \"Analysis Time: $(date)\" \u003e\u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\necho \"\" \u003e\u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\n\n# Count stats files (history)\nHISTORY_COUNT=$(ls -1 /var/lib/dagu/data/table_stats_*.json 2\u003e/dev/null | wc -l)\necho \"Historical Data Points: ${HISTORY_COUNT}\" \u003e\u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\necho \"\" \u003e\u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\n\n# Current check results\necho \"Current Quality Status:\" \u003e\u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\necho \"${CRITICAL_CHECKS}\" | jq '.statistics' \u003e\u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\necho \"\" \u003e\u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\n\n# Table counts\nTABLE_COUNT=$(echo \"${ALL_TABLES}\" | jq '.total_tables')\necho \"Total Tables Monitored: ${TABLE_COUNT}\" \u003e\u003e /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt\n\ncat /var/lib/dagu/logs/quality_trends_$(date +%Y%m%d_%H%M).txt","depends":["check_critical_tables"]},{"name":"generate_dashboard_data","description":"Prepare data for quality dashboard visualization","executorConfig":{},"script":"DASHBOARD_FILE=\"/var/lib/dagu/data/dashboard_latest.json\"\n\necho '{\n  \"last_updated\": \"'$(date -Iseconds)'\",\n  \"connection\": \"'${CONNECTION_ID}'\",\n  \"summary\": {\n    \"total_tables\": '$(echo \"${ALL_TABLES}\" | jq '.total_tables')',\n    \"checks_passed\": '$(echo \"${CRITICAL_CHECKS}\" | jq '.statistics.passed')',\n    \"checks_failed\": '$(echo \"${CRITICAL_CHECKS}\" | jq '.statistics.failed')',\n    \"checks_total\": '$(echo \"${CRITICAL_CHECKS}\" | jq '.statistics.total_expectations')'\n  },\n  \"critical_checks\": '${CRITICAL_CHECKS}',\n  \"all_tables\": '${ALL_TABLES}'\n}' | jq '.' \u003e ${DASHBOARD_FILE}\n\necho \"📊 Dashboard data updated: ${DASHBOARD_FILE}\"\ncat ${DASHBOARD_FILE} | jq '.summary'","depends":["analyze_quality_trends"]},{"name":"alert_if_degraded","description":"Check if quality has degraded and send alerts","executorConfig":{},"script":"FAILED_COUNT=$(echo \"${CRITICAL_CHECKS}\" | jq '.statistics.failed')\n\nif [ \"${FAILED_COUNT}\" -gt 0 ]; then\n  echo \"⚠️ WARNING: ${FAILED_COUNT} quality checks failed!\"\n  echo \"Review details at: http://localhost:8080\"\n  exit 1\nelse\n  echo \"✅ All quality checks passing\"\n  exit 0\nfi","depends":["generate_dashboard_data"]}],"handlerOn":{"failure":{"name":"onFailure","executorConfig":{},"script":"echo \"$(date): Quality degradation detected\" \u003e\u003e /var/lib/dagu/logs/quality_alerts.log\necho \"Failed checks: ${CRITICAL_CHECKS}\" | jq '.results[] | select(.success == false)' \u003e\u003e /var/lib/dagu/logs/quality_alerts.log"},"success":{"name":"onSuccess","executorConfig":{},"commands":[{"command":"echo","args":["$(date): All systems healthy","\u003e\u003e","/var/lib/dagu/logs/quality_health.log"],"cmdWithArgs":"echo \"$(date): All systems healthy\" \u003e\u003e /var/lib/dagu/logs/quality_health.log"}]}},"maxActiveRuns":1,"maxCleanUpTime":5000000000,"histRetentionDays":30,"maxOutputSize":1048576,"yamlData":""}